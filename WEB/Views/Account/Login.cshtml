@{
    ViewData["Title"] = "Přihlášení";
    Layout = null;
}

<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Přihlášení - Habibi Meet</title>
    <link rel="stylesheet" href="~/css/styles.css" />
    <style>
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            background: white;
            border-radius: 20px;
            padding: 3rem;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.15);
        }

            .login-card h1 {
                text-align: center;
                margin-bottom: 0.5rem;
            }

            .login-card p {
                text-align: center;
                color: #888;
                margin-bottom: 2rem;
            }

        .form-group {
            display: flex;
            flex-direction: column;
            margin-bottom: 1.2rem;
        }

            .form-group label {
                margin-bottom: 0.4rem;
                font-weight: bold;
                font-size: 0.9rem;
            }

            .form-group input {
                padding: 0.8rem 1rem;
                border-radius: 10px;
                border: 1px solid #ddd;
                font-size: 1rem;
                outline: none;
                transition: border 0.2s;
            }

                .form-group input:focus {
                    border-color: #667eea;
                }

        .login-btn {
            width: 100%;
            padding: 0.9rem;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            margin-top: 0.5rem;
            transition: opacity 0.2s;
        }

            .login-btn:hover {
                opacity: 0.9;
            }

        .login-footer {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.9rem;
            color: #888;
        }

            .login-footer a {
                color: #667eea;
                font-weight: bold;
                text-decoration: none;
            }

        .error-msg {
            background: #ffe0e0;
            color: #c00;
            padding: 0.7rem 1rem;
            border-radius: 8px;
            margin-bottom: 1rem;
            font-size: 0.9rem;
        }

        .logo-top {
            text-align: center;
            font-size: 1.5rem;
            font-weight: bold;
            color: #667eea;
            margin-bottom: 2rem;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo-top">Habibi Meet</div>
        <h1>Přihlášení</h1>
        <p>Vítej zpět!</p>
        @if (ViewBag.Error != null)
        {
            <div class="error-msg">@ViewBag.Error</div>
        }
        <form method="post">
            <div class="form-group">
                <label>Uživatelské jméno</label>
                <input type="text" name="username" placeholder="Zadej uživatelské jméno" required />
            </div>
            <div class="form-group">
                <label>Heslo</label>
                <input type="password" name="password" placeholder="Zadej heslo" required />
            </div>
            <button type="submit" class="login-btn">Přihlásit se</button>
        </form>
        <div class="login-footer">
            Nemáš účet? <a asp-controller="Account" asp-action="Register">Zaregistruj se</a>
        </div>
    </div>
</body>
</html>