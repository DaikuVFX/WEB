@model WEB.Models.User

@{
    ViewData["Title"] = "Můj profil";
}
<section class="page-header">
    <<h1>Vítej, @(Model?.DisplayName != "" ? Model?.DisplayName : ViewBag.Username)! 👋</h1>
    <p>Toto je tvůj profil na Habibi Meet</p>
</section>
<section class="about-container">
    <div class="big-box">
        <div class="small-box">
            <div class="box-icon">👤</div>
            <h2>Můj účet</h2>
            <p><strong>Uživatelské jméno:</strong> @ViewBag.Username</p>
            <p><strong>Zobrazované jméno:</strong> @(Model?.DisplayName != "" ? Model?.DisplayName : "Nenastaveno")</p>
            <p>Vítej zpět v komunitě Habibi Meet!</p>
        </div>
        <div class="small-box">
            <div class="box-icon">⚙️</div>
            <h2>Nastavení</h2>
            @if (ViewBag.Success != null)
            {
                <p style="color:green">@ViewBag.Success</p>
            }
            <form method="post" asp-action="Index">
                <label>Zobrazované jméno:</label>
                <input type="text" name="displayName" value="@Model?.DisplayName" />
                <button type="submit" class="cta-button">Uložit</button>
            </form>
            <a asp-controller="Account" asp-action="Logout" class="cta-button">Odhlásit se</a>
        </div>
    </div>
</section>