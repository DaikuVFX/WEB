@{
    ViewData["Title"] = "Funkce";
}

<section class="page-header">
    <h1>Co nabízíme</h1>
    <p>Objevte funkce, které dělají Habibi Meet výjimečným</p>
</section>

<section class="features-detail">
    <div class="feature-block reverse">
        <div class="feature-text">
            <h2>Mobilní přístup a aplikace</h2>
            <p>Měj Habibi Meet vždy u sebe. Naše aplikace je optimalizovaná pro plynulé používání na jakémkoliv zařízení.</p>
            <ul>
                <li>Plně responzivní design</li>
                <li>Notifikace v reálném čase</li>
                <li>Nízká spotřeba dat</li>
                <li>Intuitivní mobilní rozhraní</li>
            </ul>
        </div>
        <div class="feature-image">
            <img src="~/images/ManPhone.jpg" alt="Muž používající Habibi Meet na telefonu"
                 onerror="this.onerror=null;this.style.width='100%';this.style.height='350px';this.style.backgroundColor='#667eea';" />
        </div>
    </div>

    <div class="feature-block">
        <div class="feature-image">
            <img src="~/images/GuyPhone.jpg" alt="Další muž používající Habibi Meet na telefonu"
                 onerror="this.onerror=null;this.style.width='100%';this.style.height='350px';this.style.backgroundColor='#667eea';" />
        </div>
        <div class="feature-text">
            <h2>Sdílení momentů</h2>
            <p>Zachyť své nejlepší okamžiky a sdílej je se svými přáteli. Fotky, videa, stories - vše na jednom místě.</p>
            <ul>
                <li>Neomezené nahrávání fotografií</li>
                <li>HD video support</li>
                <li>Efekty a filtry</li>
                <li>24hodinové stories</li>
            </ul>
        </div>
    </div>

    <div class="feature-block reverse">
        <div class="feature-text">
            <h2>Chatování v reálném čase</h2>
            <p>Zůstaň v kontaktu s přáteli pomocí našeho rychlého a bezpečného messagingu.</p>
            <ul>
                <li>Soukromé a skupinové chaty</li>
                <li>Video a audio hovory</li>
                <li>Sdílení souborů</li>
                <li>End-to-end šifrování</li>
            </ul>
        </div>
        <div class="feature-image">
            <img src="~/images/text.webp" alt="text on phone"
                 onerror="this.onerror=null;this.style.width='100%';this.style.height='350px';this.style.backgroundColor='#667eea';" />
        </div>
    </div>

    <div class="feature-block">
        <div class="feature-text">
            <h2>Komunity a skupiny</h2>
            <p>Najdi lidi se stejnými zájmy. Připoj se ke skupinám nebo vytvoř vlastní.</p>
            <ul>
                <li>Tematické skupiny</li>
                <li>Eventy a setkání</li>
                <li>Diskuzní fóra</li>
                <li>Možnost vytváření vlastních komunit</li>
            </ul>
        </div>
        <div class="feature-image">
            <img src="~/images/groupphone.webp" alt="group of people on their phones"
                 onerror="this.onerror=null;this.style.width='100%';this.style.height='350px';this.style.backgroundColor='#667eea';" />
        </div>
    </div>
</section>

@section Scripts {
    <script>
        const animateOnScroll = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0)';
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.page-header, .feature-block, .cta-section').forEach((el, index) => {
            el.style.opacity = '0';
            el.style.transform = 'translateY(30px)';
            el.style.transition = `opacity 0.6s ease ${index * 0.1}s, transform 0.6s ease ${index * 0.1}s`;
            animateOnScroll.observe(el);
        });
    </script>
}